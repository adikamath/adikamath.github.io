---
layout: none
---

[
  {% for post in site.posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "summary" : "{{ post.description | default: post.excerpt | strip_html | normalize_whitespace | truncate: 140 | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "tags_display" : "{{ post.tags | join: ', ' | replace: '-', ' ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}",
      "date_formatted" : "{{ post.date | date: "%b %d, %Y" }}",
      "read_time" : "{{ post.content | number_of_words | plus: 224 | divided_by: site.reading_speed }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
